# DataMarket — Environment Variables
# Copy this file to .env and fill in your values for local development.
# In Databricks Apps, DATABRICKS_HOST and DATABRICKS_TOKEN are injected automatically.

# ── Databricks (auto-injected in Databricks Apps) ────────────────────────────
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your-personal-access-token
DATABRICKS_USER=you@your-domain.com

# ── Lakebase Autoscaling (Postgres) ──────────────────────────────────────────
# Get the host from: databricks postgres list-endpoints (or Compute → Lakebase → your project → Overview)
# Format: ep-<name>.database.<region>.cloud.databricks.com
LAKEBASE_HOST=ep-your-project-name.database.us-east-2.cloud.databricks.com
LAKEBASE_DB=databricks_postgres
LAKEBASE_SCHEMA=datamarket
LAKEBASE_ENDPOINT=projects/your-project-name/branches/production/endpoints/primary

# ── Deployment Mode ──────────────────────────────────────────────────────────
# DEMO_MODE=true  → persona switcher, no real UC grants (default for demos/presentations)
# DEMO_MODE=false → SSO identity from Databricks Apps headers, real UC grants executed
DEMO_MODE=true

# ── Unity Catalog Integration ────────────────────────────────────────────────
# Required for real GRANT/REVOKE execution and live column schema discovery.
# Get a warehouse ID from: databricks warehouses list
# SQL_WAREHOUSE_ID=your-sql-warehouse-id

# ── Request for Access (RFA) ─────────────────────────────────────────────────
# When enabled, access requests also fire UC RFA notifications to configured
# destinations (email, Slack, Teams, webhook). Configure destinations via:
#   databricks rfa update-access-request-destinations "destinations" catalog:your_catalog --json '...'
# RFA_ENABLED=true

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Optional: link to your published AI/BI dashboard
VITE_DASHBOARD_URL=https://your-workspace.azuredatabricks.net/sql/dashboardsv3/your-dashboard-id
